APP_NAME=NHỊP VIỆN API
APP_VERSION=0.1.0
APP_ENV=development
DEMO_SIMULATION_ENABLED=true
DOCS_ENABLED=true
# Chạy trực tiếp trên máy: sqlite:///./nhip_vien.db
# Chạy container trên cloud có ổ đĩa gắn tại /data: sqlite:////data/nhip_vien.db
DATABASE_URL=sqlite:///./nhip_vien.db
AI_SERVICE_URL=http://localhost:8010
AI_REQUEST_TIMEOUT_SECONDS=5
CORS_ORIGINS=["http://localhost:5173"]
